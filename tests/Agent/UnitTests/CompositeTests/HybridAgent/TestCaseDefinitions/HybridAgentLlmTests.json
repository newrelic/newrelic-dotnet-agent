[
    {
        "testDescription": "LLM Chat Completion Success - creates LLM events and consumes gen_ai tags",
        "operations": [
            {
                "command": "DoWorkInTransaction",
                "parameters": {
                    "transactionName": "LlmChatSuccess"
                },
                "childOperations": [
                    {
                        "command": "DoWorkInSpan",
                        "parameters": {
                            "spanName": "chat gpt-4o",
                            "spanKind": "Client"
                        },
                        "childOperations": [
                            {
                                "command": "AddOTelAttribute",
                                "parameters": {
                                    "name": "gen_ai.operation.name",
                                    "value": "chat"
                                }
                            },
                            {
                                "command": "AddOTelAttribute",
                                "parameters": {
                                    "name": "gen_ai.provider.name",
                                    "value": "openai"
                                }
                            },
                            {
                                "command": "AddOTelAttribute",
                                "parameters": {
                                    "name": "gen_ai.request.model",
                                    "value": "gpt-4o"
                                }
                            },
                            {
                                "command": "AddOTelAttribute",
                                "parameters": {
                                    "name": "gen_ai.response.model",
                                    "value": "gpt-4o-2024-08-06"
                                }
                            },
                            {
                                "command": "AddOTelAttribute",
                                "parameters": {
                                    "name": "gen_ai.output.id",
                                    "value": "chatcmpl-abc123"
                                }
                            },
                            {
                                "command": "AddOTelAttribute",
                                "parameters": {
                                    "name": "gen_ai.input.messages",
                                    "value": "[{\"role\":\"system\",\"parts\":[{\"type\":\"text\",\"content\":\"You are a helpful assistant.\"}]},{\"role\":\"user\",\"parts\":[{\"type\":\"text\",\"content\":\"What is the capital of France?\"}]}]"
                                }
                            },
                            {
                                "command": "AddOTelAttribute",
                                "parameters": {
                                    "name": "gen_ai.output.messages",
                                    "value": "[{\"role\":\"assistant\",\"parts\":[{\"type\":\"text\",\"content\":\"The capital of France is Paris.\"}],\"finish_reason\":\"stop\"}]"
                                }
                            },
                            {
                                "command": "AddOTelAttribute",
                                "parameters": {
                                    "name": "telemetry.sdk.version",
                                    "value": "1.0.0"
                                }
                            },
                            {
                                "command": "AddOTelAttribute",
                                "parameters": {
                                    "name": "gen_ai.usage.input_tokens",
                                    "value": 25,
                                    "type": "int"
                                }
                            },
                            {
                                "command": "AddOTelAttribute",
                                "parameters": {
                                    "name": "gen_ai.usage.output_tokens",
                                    "value": 10,
                                    "type": "int"
                                }
                            },
                            {
                                "command": "AddOTelAttribute",
                                "parameters": {
                                    "name": "custom.llm.tag",
                                    "value": "should-remain"
                                }
                            }
                        ]
                    }
                ]
            }
        ],
        "agentOutput": {
            "transactions": [
                {
                    "name": "LlmChatSuccess"
                }
            ],
            "spans": [
                {
                    "name": "chat gpt-4o",
                    "parentName": "LlmChatSuccess",
                    "category": "generic",
                    "attributes": {
                        "custom.llm.tag": "should-remain"
                    }
                }
            ],
            "customEvents": [
                {
                    "type": "LlmChatCompletionSummary",
                    "attributes": {
                        "request.model": "gpt-4o",
                        "response.model": "gpt-4o-2024-08-06",
                        "vendor": "openai",
                        "ingest_source": "DotNet",
                        "response.choices.finish_reason": "stop"
                    }
                },
                {
                    "type": "LlmChatCompletionMessage",
                    "attributes": {
                        "role": "user",
                        "content": "What is the capital of France?",
                        "vendor": "openai",
                        "ingest_source": "DotNet"
                    }
                },
                {
                    "type": "LlmChatCompletionMessage",
                    "attributes": {
                        "role": "assistant",
                        "content": "The capital of France is Paris.",
                        "is_response": "True",
                        "vendor": "openai",
                        "ingest_source": "DotNet"
                    }
                }
            ]
        }
    },
