{
  "packages": {
    ".": {
      "changelog-path": "src/Agent/CHANGELOG.md",
      "release-type": "go",
      "bump-minor-pre-major": false,
      "bump-patch-for-minor-pre-major": false,
      "draft": false,
      "prerelease": false,
      "changelog-sections": [
        {
          "type": "notice",
          "section": "Notice",
          "hidden": false
        },
        {
          "type": "feat",
          "section": "New features",
          "hidden": false
        },
        {
          "type": "fix",
          "section": "Fixes",
          "hidden": false
        },
        {
          "type": "security",
          "section": "Security",
          "hidden": false
        }
      ]
    },
    "src/Agent/NewRelic/Agent/Core/Config": {
      "release-type": "simple",
      "component": "config-schema",
      "include-component-in-tag": true,
      "include-v-in-tag": false,
      "tag-separator": "-",
      "skip-changelog": true,
      "skip-github-release": true,
      "extra-files": [
        {
          "type": "yaml",
          "path": "/.fleetControl/configurationDefinitions.yml",
          "jsonpath": "$.configurationDefinitions[0].version"
        }
      ]
    }
  },
  "plugins": ["sentence-case"],
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json"
}
